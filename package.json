{
  "name": "field-theory-ui",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "GitMaxd",
  "homepage": "https://github.com/Gitmaxd/field-theory-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gitmaxd/field-theory-ui.git"
  },
  "keywords": [
    "twitter",
    "bookmarks",
    "dashboard",
    "local-first",
    "langchain"
  ],
  "description": "Local-first web UI for fieldtheory CLI bookmark data",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "server": "tsx server/index.ts",
    "mcp": "tsx server/mcp/index.ts",
    "start": "npm run build && npm run server",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "generate:prompt": "tsx scripts/generate-openui-prompt.ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.4",
    "@langchain/tavily": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openuidev/react-lang": "^0.1.5",
    "@openuidev/react-ui": "^0.10.2",
    "@radix-ui/react-slot": "^1.2.4",
    "better-sqlite3": "^11.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.1",
    "langchain": "^1.3.1",
    "lucide-react": "^0.500.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^2.15.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "jsdom": "^25.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
