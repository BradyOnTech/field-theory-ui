# Field Theory UI -- Environment Configuration
# Copy this file to .env and fill in the values you need.

# Server
PORT=3939

# Data directory (where bookmarks.db lives)
# FT_DATA_DIR=~/.ft-bookmarks

# Oracle Pro Mode (optional -- set ONE of these to enable LLM-powered SQL agent)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Web Search (optional -- enables TavilySearch tool for supplementing bookmark data with web results)
# TAVILY_API_KEY=tvly-...

# Pro Chat Model (optional -- overrides the auto-detected default)
# Format: provider:model-id
# CHAT_MODEL=anthropic:claude-sonnet-4-6
#
# Anthropic options:
#   anthropic:claude-opus-4-6       $5/$25 per MTok  (most capable)
#   anthropic:claude-sonnet-4-6     $3/$15 per MTok  (default -- fast + capable)
#   anthropic:claude-haiku-4-5      $1/$5 per MTok   (fastest, cheapest)
#
# OpenAI options:
#   openai:gpt-5.4                  $2.50/$15 per MTok  (most capable)
#   openai:gpt-5.4-mini             $0.75/$4.50 per MTok  (default -- fast + cheap)
#   openai:gpt-5.4-nano             $0.20/$1.25 per MTok  (cheapest)

# LangSmith Tracing (optional -- enables observability for LangChain agent calls)
# Sign up at https://smith.langchain.com to get an API key.
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2-...
# LANGSMITH_PROJECT=Field Theory UI
